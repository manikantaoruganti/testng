{
  "name": "crisis-os",
  "version": "1.0.0",
  "description": "Autonomous Crisis Response Operating System",
  "main": "server/src/server.js",
  "scripts": {
    "client:dev": "cd client && vite",
    "client:build": "cd client && vite build",
    "server:dev": "nodemon server/src/server.js",
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "start": "node server/src/server.js",
    "lint": "eslint .",
    "seed": "node server/src/db/seed.js"
  },
  "keywords": [
    "crisis",
    "response",
    "real-time",
    "full-stack"
  ],
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^8.4.0",
    "axios": "^1.6.7",
    "concurrently": "^8.2.2",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.4",
    "lucide-react": "^0.344.0",
    "mongoose": "^8.2.2",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.3",
    "recharts": "^2.12.2",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@vitejs/plugin-react-oxc": "^0.4.3",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "nodemon": "^3.1.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^8.0.3"
  }
}
